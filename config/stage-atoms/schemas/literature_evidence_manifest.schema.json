{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LiteratureEvidenceManifest",
  "description": "Manifest of source artifacts retrieved by the literature atoms. Each entry binds a PMID to a stored source file, its hashes, and its redistribution status.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pmid", "source_kind", "path", "sha256_binary", "sha256_extracted_text",
                     "extracted_text_normalization", "bytes", "retrieval_ts", "retrieval_query_id",
                     "redistributable", "license"],
        "additionalProperties": false,
        "properties": {
          "pmid": { "type": "string", "pattern": "^[1-9][0-9]{6,8}$" },
          "source_kind": { "type": "string", "enum": ["pmc_oa_full_text", "abstract_only", "external_pdf_local_only"] },
          "path": { "type": "string", "not": { "pattern": "(^/|(^|/)\\.\\.(/|$))" } },
          "sha256_binary": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "sha256_extracted_text": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "extracted_text_normalization": { "type": "string", "const": "collapse_whitespace_lowercase_v1" },
          "bytes": { "type": "integer", "minimum": 0 },
          "retrieval_ts": { "type": "string", "format": "date-time" },
          "retrieval_query_id": { "type": "string", "pattern": "^q[0-9]{3,}$" },
          "redistributable": { "type": "boolean" },
          "license": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
