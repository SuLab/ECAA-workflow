  "bucketingRules": [
    {
      "id": "GEO",
      "description": "Take the accession prefix and all digit characters except the last three, then append 'nnn'.",
      "algorithm": "prefix + digits[0..length-3] + 'nnn'",
      "exampleInput": "GSE12345",
      "exampleBucket": "GSE12nnn"
    }
  ],
  "verificationPolicy": "resolve_and_confirm_http_200",
  "resolutionMethod": "hints_with_runtime_fallback",
  "fallbackResolutionPolicy": {
    "enabled": true,
    "strategies": [
      "repository_api_query",
      "pubmed_associated_data_lookup",
      "data_availability_statement_parsing",
      "cross_reference_registry_lookup"
    ],
    "log_target": "runtime_logs/SOURCE_DISCOVERY_LOG.jsonl",
    "event_type": "locator_resolution_fallback"
  },
  "verificationNote": "Accession patterns are resolution hints, not deterministic lookups. The executor should use these patterns as a starting point. If a pattern fails to resolve (non-200 response or missing data), the executor should fall back to alternative resolution strategies: repository API queries, PubMed metadata lookups, and data availability statement parsing. All resolution attempts and results must be logged in SOURCE_DISCOVERY_LOG.jsonl."
