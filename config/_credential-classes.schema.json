{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "swfc:credential-classes",
  "description": "v4 Phase 4 / D6 / F21 — credential classes consulted by UnblockPath::Waiver and UnblockPath::EscalateToReviewer. Each class names a role that can sign off on a waiver / escalation; audit_required directs the server to record sign-off in the decision log; requires_co_signature enforces additional signers before a waiver is honored.",
  "type": "object",
  "required": ["version", "classes"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "audit_required": {
            "type": "boolean",
            "default": false
          },
          "requires_co_signature": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            },
            "uniqueItems": true
          }
        }
      },
      "minItems": 1
    }
  }
}
