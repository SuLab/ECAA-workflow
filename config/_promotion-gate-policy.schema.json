{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ecaax:promotion-gate-policy",
  "title": "PromotionGatePolicy",
  "description": "v4 alignment Phase 3 (D8 / F19) — validation × lifecycle promotion grid. Loaded into PlanningContext.promotion_gate; consulted by composer_v4::policy_gate::consult_promotion_gate at every promotion attempt. Ad-hoc promotion logic in code is forbidden (F19).",
  "type": "object",
  "required": ["version", "states"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "states": {
      "type": "object",
      "required": [
        "hypothesized",
        "contracted",
        "implemented",
        "locally_validated",
        "benchmark_validated",
        "production"
      ],
      "additionalProperties": false,
      "patternProperties": {
        "^(hypothesized|contracted|implemented|locally_validated|benchmark_validated|production)$": {
          "$ref": "#/$defs/StateRequirements"
        }
      }
    }
  },
  "$defs": {
    "StateRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract":              { "$ref": "#/$defs/ClassRequirement" },
        "golden":                { "$ref": "#/$defs/ClassRequirement" },
        "metamorphic":           { "$ref": "#/$defs/ClassRequirement" },
        "biological_invariant":  { "$ref": "#/$defs/ClassRequirement" },
        "statistical_sanity":    { "$ref": "#/$defs/ClassRequirement" },
        "reproducibility":       { "$ref": "#/$defs/ClassRequirement" },
        "notes":                 { "type": "string" },
        "required_approvals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["approval_class"],
            "additionalProperties": false,
            "properties": {
              "approval_class": {
                "type": "string",
                "pattern": "^[a-z][a-z_]*$"
              }
            }
          }
        }
      }
    },
    "ClassRequirement": {
      "oneOf": [
        { "const": "required" },
        { "const": "optional" },
        {
          "type": "object",
          "required": ["min_count"],
          "additionalProperties": false,
          "properties": {
            "min_count": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    }
  }
}
