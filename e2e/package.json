{
  "name": "scripps-workflow-e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright end-to-end test suite for the scripps-workflow natural-chat UI. Tier 1 (mocked) runs against vite preview with page.route mocking. Tier 2 (live) boots the real server against Anthropic.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:mobile": "playwright test --project=mobile-chrome",
    "test:live": "PLAYWRIGHT_LIVE=1 playwright test tests/live",
    "test:live:scenarios": "PLAYWRIGHT_LIVE=1 playwright test tests/live/scenarios",
    "install-browsers": "playwright install --with-deps chromium firefox"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.58.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.7.0"
  }
}
