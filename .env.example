# Example environment for scripps-workflow.
# Copy to `.env` (gitignored) and fill in the values you need.
#
# Only the server loads `.env` automatically (via dotenvy in
# crates/server/src/main.rs). The harness and CLI read env vars
# from the live shell — `source .env` before invoking them, or rely
# on `make` targets that pass the vars through.
#
# =============================================================================
# Production baseline (recommended active settings)
# =============================================================================
# A production deployment should set the following and leave everything else
# at its code default unless a specific operator need applies:
#
#   SWFC_ANTHROPIC_API_KEY=sk-ant-...  # required for chat-side LLM
#                                      # (legacy ANTHROPIC_API_KEY accepted
#                                      # with deprecation warning)
#   SWFC_EXECUTOR_MODE=local           # or `aws` / `slurm` (see below)
#   SWFC_HARNESS_CONCURRENCY=1         # or `auto` on a multi-core host
#   SWFC_SESSION_TOKEN_BUDGET=500000   # per-session uncached-input ceiling
#   SWFC_AUTO_TITLE=1                  # one Haiku call per session (~$0.0006)
#
# AWS or SLURM deployments additionally need the full required block from the
# matching section below. Dev/test knobs (`SWFC_LIVE_API`, `PLAYWRIGHT_LIVE`,
# `KEEP_PACKAGE`, `SWFC_DEBUG_TOKEN_BURN`, `SWFC_MOCK_DISCOVERY_BLOCK`) should
# NOT be set in production.

# =============================================================================
# LLM backend
# =============================================================================
# Required for the live Anthropic path (chat server, chat-llm CLI, nightly
# scorer, live Playwright specs). When unset the server falls back to
# MockLlmBackend and chat-llm / live tests SKIP.
#
# NOTE: This key is for the CHAT LLM only (the UX-shim conversation layer).
# The per-task Claude Code EXECUTOR agent defaults to SUBSCRIPTION billing
# at ~/.claude/.credentials.json (Max/Pro plan). The SWFC-prefixed name
# prevents accidental collisions with Claude Code CLI's ANTHROPIC_API_KEY
# scan. Legacy `ANTHROPIC_API_KEY` is still accepted (with a one-time
# stderr deprecation warning) to keep existing .env files working.
# See SWFC_AGENT_BILLING below.
SWFC_ANTHROPIC_API_KEY=sk-ant-api03-...

# Override the Anthropic API base URL (proxy, staging). Default: https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Agent billing mode. Controls whether scripts/agent-claude.sh invokes
# `claude-code` against the subscription (default) or the API.
#   subscription — unset SWFC_ANTHROPIC_API_KEY for the agent; use
#                  ~/.claude/.credentials.json. Per-task cost: $0
#                  (subscription quotas apply). Default.
#   api          — forward SWFC_ANTHROPIC_API_KEY into the agent env; each
#                  task bills the API at token × rate. Use only for CI
#                  or hosts without a subscription.
SWFC_AGENT_BILLING=subscription

# Per-task model tiering. With =1 (default), agent routes by task class:
#   discover_*    → Opus 4.7    (analytical scoring; depth pays off)
#   validate_*    → Sonnet 4.6  (stable codegen shape; 5× cheaper than Opus)
#   data_acq      → Sonnet 4.6
#   data_import   → Sonnet 4.6
#   everything else → Sonnet 4.6
# Quality safety net: validate_* still runs after every analytical task
# with explicit integrity checks; Sonnet writes stable validation
# scripts reliably. Subscription billing benefits too — Anthropic's
# quota meters token consumption regardless of mode. Set =0 to revert
# to all-Opus when maximum quality is required regardless of cost.
# SWFC_AGENT_MODEL_TIER=0

# Hard per-task cost ceiling (USD). claude CLI's --max-budget-usd
# terminates the agent session when running cost crosses the limit;
# this replaces the prior post-hoc enforce_turn_budget_limit (which
# only blocked AFTER the agent had already spent the tokens).
# Calibrated against measured per-class averages — tasks normally
# finish well under the cap, the cap catches the long tail where the
# agent loops on the last 30% after artifacts are already produced.
#
# Per-class overrides:
#   SWFC_AGENT_BUDGET_USD_VALIDATE=0.75
#   SWFC_AGENT_BUDGET_USD_DISCOVER=1.50
#   SWFC_AGENT_BUDGET_USD_DATA_ACQ=1.20
#   SWFC_AGENT_BUDGET_USD_ANALYTICAL=1.75
#
# Global override beats per-class. Set to 0 to disable the cap entirely.
# SWFC_AGENT_BUDGET_USD=2.00

# Verbose tracing inside scripts/agent-claude.sh (dispatch context, mount
# inspection, credential refresh). Default: 0.
SWFC_AGENT_DEBUG=1

# =============================================================================
# Chat server
# =============================================================================
# Bind interface. Default 127.0.0.1 (loopback). 0.0.0.0 exposes on LAN;
# the server REFUSES TO BOOT on a non-loopback bind unless either
# SWFC_SERVER_AUTH_TOKEN is set or SWFC_SERVER_LAN_NO_AUTH=1 is the
# explicit opt-in.
# SWFC_BIND_ADDR=127.0.0.1

# HTTP listen port. Default 3000. Must match SWFC_SERVER_URL's port and
# the UI proxy's VITE_API_PORT — the `dev_port_drift` test guards this.
# SWFC_PORT=3000

# Bearer token required for every request when the server binds anything
# other than 127.0.0.1, and accepted as an opt-in shared secret on
# loopback. Generate with `openssl rand -hex 32` and pass via
# `Authorization: Bearer <token>` from the UI / curl. Unset on loopback
# = no auth required (single-user dev). Required for non-loopback bind.
# SWFC_SERVER_AUTH_TOKEN=

# Explicit opt-in to bind LAN-exposed (non-loopback) WITHOUT a token.
# Without this, the server fails closed on a non-loopback bind that
# lacks SWFC_SERVER_AUTH_TOKEN. Do not use in production — only for
# isolated dev VLANs.
# SWFC_SERVER_LAN_NO_AUTH=1

# Allowed CORS Origins (comma-separated). Default covers the dev UI on
# :5173 + :3000 in both 127.0.0.1 and localhost forms. Override to the
# actual UI host(s) for production deployments.
# SWFC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Disable per-session owner authorization (debug only). With =1, any
# authenticated request can read/write any session. Used by the
# crates/server/tests/owner_authz.rs bypass branch. Never in production.
# SWFC_OWNER_AUTHZ_DISABLE=1

# Bypass the per-server flock (RC-22 multi-server tests). Default off;
# setting =1 lets a second server attach to a session already locked by
# another instance. Tests only.
# SWFC_SERVER_DEBUG_ALLOW_MULTI_PROCESS=1

# `offline` forces the server onto MockLlmBackend even if SWFC_ANTHROPIC_API_KEY is
# set. Kill switch for UI work when the LLM is unavailable.
# SWFC_CHAT_MODE=offline

# Directory where chat sessions are persisted. Default: ~/.scripps-workflow/sessions
SWFC_CHAT_SESSIONS_DIR=/tmp/scripps-chat-sessions

# Config root used by the chat server (taxonomies, modality keywords, policies).
# Default: ./config (resolved relative to CWD).
# SWFC_CONFIG_DIR=./config

# Override the search root when the chat tools look up emitted packages by name.
# Default: ~/.scripps-workflow/packages
SWFC_PACKAGE_ROOT=~/.scripps-workflow/packages

# Composer engine selection on session creation.
#   semantic|proof-carrying — v4 proof-carrying planner (default; aliases)
# Phase 6 of the gap-closure plan (2026-05-08) retired the legacy values
# `legacy`, `archetypes`, and `backward-chain`. If set on a new session,
# the server emits a tracing::warn! and routes to v4. Existing sessions
# retain their persisted composer_version across reload.
SWFC_COMPOSER=semantic

# Override the path to config/model-policy.yaml for ad-hoc experimentation.
# SWFC_MODEL_POLICY_PATH=/path/to/model-policy.yaml

# Override the confidence threshold at which the model policy escalates
# Sonnet → Opus. Default sourced from model-policy.yaml (0.3). Must be
# a float in [0.0, 1.0]; out-of-range or non-numeric values are ignored
# with a stderr warning.
# SWFC_MODEL_ROUTING_CONFIDENCE_THRESHOLD=0.3

# Session-store load mode. permissive (default) skips a corrupted file
# with a warning; strict fails the whole load. Test sites bias to strict.
# SWFC_SESSION_LOAD_MODE=strict

# Cadence of the session-store TTL prune sweep (seconds). Default 3600
# (1 hour). The prune removes sessions inactive longer than 30 days.
# SWFC_TTL_PRUNE_INTERVAL_SECS=3600

# Per-request body size cap (KiB). Default 256. Bumped automatically by
# the streaming upload code path (which has its own SWFC_UPLOAD_*
# bounds), so this cap is only the JSON-RPC ceiling.
# SWFC_REQUEST_BODY_LIMIT_KB=256

# Per-request wall-clock timeout (seconds). Default 60. SSE streams
# bypass this guard.
# SWFC_REQUEST_TIMEOUT_SECS=60

# Idempotency-Key cache TTL (seconds). Default 3600 (1 hour). Replays
# inside this window with the same body short-circuit to the cached
# response — see crates/server/src/chat_routes/_idempotency.rs.
# SWFC_IDEMPOTENCY_TTL_SECS=3600

# Per-endpoint LLM rate limits (requests / minute, per-IP via
# tower-governor). All have safe production defaults; bump in dev when
# the UI's polling endpoints saturate the global limit and need
# isolation. See crates/server/src/chat_routes/_rate_limits.rs.
#   SWFC_LLM_RATE_LIMIT_TURN          POST /turn                (default 30)
#   SWFC_LLM_RATE_LIMIT_SCORE         scoring side-call         (default 6)
#   SWFC_LLM_RATE_LIMIT_EXPLAIN       explain side-call         (default 30)
#   SWFC_LLM_RATE_LIMIT_SUMMARY       summary side-call         (default 6)
#   SWFC_LLM_RATE_LIMIT_REMEDIATION   remediation-proposer      (default 6)
#   SWFC_LLM_RATE_LIMIT_START_EXEC    POST /start-execution     (default 12)
#   SWFC_LLM_RATE_LIMIT_BRANCH        POST /branch              (default 6)
# SWFC_LLM_RATE_LIMIT_TURN=30
# SWFC_LLM_RATE_LIMIT_SCORE=6
# SWFC_LLM_RATE_LIMIT_EXPLAIN=30
# SWFC_LLM_RATE_LIMIT_SUMMARY=6
# SWFC_LLM_RATE_LIMIT_REMEDIATION=6
# SWFC_LLM_RATE_LIMIT_START_EXEC=12
# SWFC_LLM_RATE_LIMIT_BRANCH=6

# Read-only shared-URL middleware. =1 honors session-share tokens for
# unauthenticated browsers. Default 0; without it the middleware is a
# no-op (every request passes through).
# SWFC_SHARED_URLS_ENABLED=1

# Disposition auto-apply (TEST ONLY). =1 auto-applies disposition decisions
# the agent emits, skipping SME confirmation. Do not set in production —
# the disposition unit tests intentionally clear it.
# SWFC_AUTO_APPLY_DISPOSITIONS=1

# Input listing + upload bounds (chat-routes inputs/upload routes).
# Tune when SMEs work with large cohort directories or upload-driven
# pipelines saturate the server's disk reserve.
# - SWFC_INPUT_ROOTS=<colon-separated>: allowlist of filesystem roots
#   SMEs may point local_path inputs at. Default user-home only.
# - SWFC_INPUT_MAX_FILES=<n>: max files listed (default 50000).
# - SWFC_INPUT_MAX_FILE_BYTES=<n>: per-file byte cap (default 50 GB).
# - SWFC_INPUT_MAX_TOTAL_BYTES=<n>: total bytes across listed files
#   (default 250 GB).
# - SWFC_UPLOAD_ROOT=<dir>: root for uploaded session files
#   (default ~/.scripps-workflow/uploads).
# - SWFC_UPLOAD_MAX_BYTES=<n>: per-upload byte cap.
# - SWFC_UPLOAD_DISK_RESERVE_GB=<n>: bail out of new chunk writes when
#   free space on the upload root's filesystem falls below this (default 50).
SWFC_INPUT_ROOTS=/data:/scratch
# SWFC_INPUT_MAX_FILES=50000
# SWFC_INPUT_MAX_FILE_BYTES=53687091200
# SWFC_INPUT_MAX_TOTAL_BYTES=268435456000
# SWFC_UPLOAD_ROOT=~/.scripps-workflow/uploads
# SWFC_UPLOAD_MAX_BYTES=53687091200
# SWFC_UPLOAD_DISK_RESERVE_GB=50

# Auto-register filesystem path hints extracted from intake prose
# (chat-side `append_intake_prose`). When `=1`, any path-shaped token
# in the SME's prose that resolves under SWFC_INPUT_ROOTS is promoted
# directly onto `session.inputs` — no follow-up confirmation prompt.
# Useful in non-interactive fixture runs where no SME is present to
# approve the registration. Default off (interactive flow surfaces the
# hint via get_session_state + the UI offers to register).
# SWFC_AUTO_REGISTER_PROSE_PATHS=1

# Anthropic client + token-burn knobs (chat side only; the per-task
# agent runs through scripts/agent-claude.sh's own credential path).
# - SWFC_ANTHROPIC_TIMEOUT_SECS=<n>: HTTP timeout for the Messages API
#   (default 180; was 120 pre plan §S2.7). Long generations on
#   Sonnet/Opus + tool loops can exceed 60–90s.
# - SWFC_ANTHROPIC_RPM=<n>: requests-per-minute cap on outbound calls.
#   Default unset (no cap). Set when the deployment hits a rate-limit.
# - SWFC_DISABLE_CONTEXT_EDITING=1: disables `context-management-2025-06-27`
#   (auto-clears stale tool_result blocks after 8 iterations; default on).
# - SWFC_SLIM_TAXONOMY=1: strips per-stage descriptions from the
#   taxonomy prompt to shrink uncached input.
# - SWFC_SESSION_TOKEN_BUDGET=<n>: soft-blocks the tool loop at this
#   many uncached input tokens (default 500000; cache-read doesn't
#   bill, so the budget tracks fresh content only).
# - SWFC_BUDGET_HARD_STOP=1: with SWFC_SESSION_TOKEN_BUDGET set, the
#   tool loop refuses to start a new turn once the soft-block ceiling
#   is crossed (default warn-only). CI fixtures use this to gate spend.
# - SWFC_DEFAULT_SESSION_BUDGET_USD=<n>: server-side default
#   session-level cost cap (USD). Per-session overrides via the
#   Settings UI; this is the fall-through default.
# - SWFC_ALLOW_1H_CACHE=1: permits ttl: "1h" on cache_control entries.
#   Default rejected (5m only).
# - SWFC_DEBUG_TOKEN_BURN=1: streams per-turn token/cache/cost to
#   stderr, warns at cache-hit <30% after ≥3 turns. Debug only.
# - SWFC_DEBUG=1: master debug gate. SWFC_DUMP_ANTHROPIC_PAYLOAD is
#   ignored unless this is set (refuses-by-default so a forgotten dump
#   path doesn't leak prompts into operator log directories).
# - SWFC_DUMP_ANTHROPIC_PAYLOAD=<file>: writes JSON of every outbound
#   Messages API request (mode 0600, appended). Use per-session paths
#   like /tmp/swfc-payload-$SESSION.jsonl. Gated on SWFC_DEBUG=1.
# SWFC_ANTHROPIC_TIMEOUT_SECS=180
# SWFC_ANTHROPIC_RPM=50
# SWFC_DISABLE_CONTEXT_EDITING=1
# SWFC_SLIM_TAXONOMY=1
SWFC_SESSION_TOKEN_BUDGET=500000
# SWFC_BUDGET_HARD_STOP=1
# SWFC_DEFAULT_SESSION_BUDGET_USD=50
# SWFC_ALLOW_1H_CACHE=1
# SWFC_DEBUG_TOKEN_BURN=1
# SWFC_DEBUG=1
# SWFC_DUMP_ANTHROPIC_PAYLOAD=/tmp/swfc-anthropic-payload.jsonl

# Git-backed provenance.
# - SWFC_GIT_ENABLED=0 hard-disables the feature regardless of the
#   Settings UI checkbox. Any other value (or absent) is config-driven
#   (default off in ~/.scripps-workflow/git-config.json).
# - SWFC_GIT_CONFIG_PATH=<path>: override config-file path (default
#   ~/.scripps-workflow/git-config.json).
# - SWFC_GIT_REPO_ROOT=<absolute-path>: operator escape hatch.
#   GitConfig::validate requires repo_path to canonicalize under $HOME;
#   set this to an additional absolute root that's also acceptable
#   (e.g., a shared /var/scripps/packages mount).
SWFC_GIT_ENABLED=0
# SWFC_GIT_CONFIG_PATH=~/.scripps-workflow/git-config.json
# SWFC_GIT_REPO_ROOT=/var/scripps/packages

# =============================================================================
# Compute backend (harness)
# =============================================================================
# Which Executor to use.
#   local  — runs the agent as a subprocess on this host (default)
#   aws    — provisions EC2 via the aws CLI (see AWS section below)
#   slurm  — submits sbatch jobs over SSH to a SLURM cluster (see SLURM section below)
# `mock` exists as a test-only constructor; not dispatched from the factory.
SWFC_EXECUTOR_MODE=local

# =============================================================================
# Literature retrieval (literature_context tool + literature_* DAG tasks)
# =============================================================================
# Source-scope tier for evidence retrieval. Three values:
#   pmc_oa                  — PubMed Central Open Access subset (default)
#   pmc_oa_plus_abstracts   — also pulls PubMed/E-utilities abstracts
#   all_sources_local_only  — phase-2 stub (institutional access)
# Invalid values fall back to pmc_oa with a stderr warning.
SWFC_LIT_SOURCE_SCOPE=pmc_oa_plus_abstracts

# NCBI E-utilities API key. Unset = 3 req/s. Set = 10 req/s. Never logged.
# SWFC_LIT_NCBI_API_KEY=

# Per-task literature evidence size cap (MB). Default 200. On hit,
# result.json carries `truncated_at_storage_cap: true`. Soft-truncate,
# not a blocker.
# SWFC_LIT_EVIDENCE_MAX_MB=200

# Phase-2 stub for `all_sources_local_only`. No-op when set against any
# other scope. Not for production.
# SWFC_LIT_INSTITUTIONAL_ACCESS=1

# Disable the literature_context tool entirely. Used by external-eval
# adapters (Biomni, BioMedAgent) to force parity comparisons without
# the literature shim. Default off.
# SWFC_LITERATURE_CONTEXT_DISABLED=1

# Playwright literature.spec.ts live-API gate. Default off (the spec
# SKIPS without it).
# SWFC_LIT_LIVE_API=1

# =============================================================================
# AWS provisioning — required when SWFC_EXECUTOR_MODE=aws
# =============================================================================
# See docs/remote-compute-operator-reference.md for the full operator runbook.
# Every var below is no-op when SWFC_EXECUTOR_MODE=local.

# EC2 region for provisioning.
# SWFC_AWS_REGION=us-west-2

# AMI the harness launches. Produce with the Packer template in scripts/packer/.
# SWFC_AWS_AMI_ID=ami-0123456789abcdef0

# Security group attached to provisioned instances. Must allow outbound 443 for
# SSM and S3.
# SWFC_AWS_SECURITY_GROUP=sg-0123456789abcdef0

# IAM instance profile — required for SSM RunCommand + S3 access.
# SWFC_AWS_INSTANCE_PROFILE=scripps-workflow-agent

# VPC subnet(s). Set either a single subnet OR a comma-separated list for
# multi-AZ failover (multi_az_policy rotates on InsufficientInstanceCapacity).
# SWFC_AWS_SUBNET_ID=subnet-0123456789abcdef0
# SWFC_AWS_SUBNET_IDS=subnet-aaa,subnet-bbb,subnet-ccc

# Optional EC2 key pair for SSH break-glass debugging. SSM is the primary
# control channel.
# SWFC_AWS_KEY_PAIR=scripps-ops

# S3 bucket + key prefix used to stage package inputs and collect outputs.
# Defaults: scripps-workflow / scripps-workflow/
# SWFC_AWS_S3_BUCKET=scripps-workflow
# SWFC_AWS_S3_PREFIX=scripps-workflow/

# Short SHA of the harness workspace. Tagged onto every provisioned instance
# so scan_orphans can correlate. Default: "unknown".
# SWFC_WORKSPACE_SHA=$(git rev-parse --short HEAD)

# =============================================================================
# AWS policy knobs
# =============================================================================
# true = request spot capacity with CapacityRebalance=true. Default: false.
# SWFC_AWS_SPOT=true

# REQUIRED when SWFC_EXECUTOR_MODE=aws. Hard USD cap — provision aborts if the
# estimated run cost exceeds the ceiling. Phase 9 (Task 9.1, closes F-EXEC-C-02):
# the harness now fails closed without an explicit positive ceiling. Operators
# that don't want a ceiling at all should run the non-AWS executors (local /
# slurm) which use NoopCostModel.
SWFC_AWS_COST_CEILING_USD=10.00

# Phase 9 (Task 9.2) — optional comma-separated allowlist of EC2 instance
# types the harness is permitted to launch. Unset = any instance type the
# sizing layer chooses. Recommended starting set covers the workloads the
# default sizing tables emit; tighten further for prod operators.
# SWFC_AWS_INSTANCE_TYPE_ALLOWLIST=t3.medium,m6i.large,m6i.xlarge,m6i.2xlarge,r6i.large,r6i.xlarge,c6i.large,c6i.xlarge,g5.xlarge,g5.2xlarge

# What to do when a task exceeds its sizing high-water mark.
#   block    — halt the task
#   resize   — upgrade to the next shape that fits (default)
#   continue — warn and run anyway
# SWFC_AWS_HIGH_WATER_POLICY=resize

# Orphan instance policy.
#   warn — log orphaned i-XXXX without terminating (default)
#   reap — actively terminate orphans
# Any other value is treated as warn. CI lanes should set =reap so a
# leaked instance from a prior flaky run is terminated automatically.
# SWFC_AWS_ORPHAN_POLICY=warn

# Per-task SSM command timeout (seconds). Default: 3600. Per-stage overrides
# come from policies/compute-resource-policy.json inside each emitted package.
# SWFC_AWS_SSM_TIMEOUT_SECS=3600

# Verified-orphan sweep deadline (seconds). The harness times out the
# secondary describe-instances confirmation step after this long.
# Default: 300.
# SWFC_AWS_ORPHAN_VERIFY_TIMEOUT_SECS=300

# Regional pricing multiplier applied to the bundled instance-type
# pricing table. Default 1.0 (us-west-2 reference). Validated as a
# finite float in [0.5, 5.0] at config load.
# SWFC_AWS_PRICING_REGION_MULT=1.10

# Override the bundled pricing table. Accepts EITHER inline JSON OR a
# path to a JSON file. Schema: { "instance-type": <USD/hr>, ... }.
# Unspecified types continue to use bundled × SWFC_AWS_PRICING_REGION_MULT.
# SWFC_AWS_PRICING_OVERRIDES_JSON=/etc/scripps/aws-pricing.json
# SWFC_AWS_PRICING_OVERRIDES_JSON={"r6i.8xlarge":2.10}

# Spot bid price as a fraction of on-demand. Default 0.30. Higher
# values reduce spot-loss probability at higher cost.
# SWFC_AWS_SPOT_DISCOUNT_FRACTION=0.30

# Cumulative spend cap across the entire harness run (USD). Default
# 100. Differs from SWFC_AWS_COST_CEILING_USD which gates a single
# dispatch. On breach the harness halts and surfaces
# BlockerKind::CostCeilingExceeded.
# SWFC_AWS_RUN_TOTAL_CEILING_USD=100.00

# Security group for tasks whose atom carries `safety.network: none`.
# Required when the DAG contains any such task — the harness refuses
# dispatch otherwise. The SG should drop all outbound traffic.
# SWFC_AWS_RESTRICTED_SG_ID=sg-0fedcba9876543210

# =============================================================================
# Agent-side (used by scripts/agent-claude-aws.sh on the provisioned host)
# =============================================================================
# AWS credential profile for the CloudWatch MCP server. Default: default
# SWFC_AWS_PROFILE=default

# Populated by the AwsExecutor at dispatch time so the agent can tag
# CloudWatch queries with the right InstanceId dimension. Do not set by hand.
# SWFC_AWS_INSTANCE_ID=i-0123456789abcdef0

# Test-only handles into the AWS executor's command-cache. Not for
# production use; the integration tests set these to pin behavior.
# SWFC_AWS_ENV_LOCK=1
# SWFC_AWS_COMMAND_ID=cmd-XXXX

# Toggle MCP-server blocks in the agent's .mcp.json. All default to 0.
# Set =1 to enable the corresponding MCP server for an AWS-side agent.
# SWFC_MCP_AWS_AGENT_REGISTRY=1
# SWFC_MCP_BIO=1
# SWFC_MCP_GITHUB=1

# =============================================================================
# Harness scheduler
# =============================================================================
# Parallel-dispatch budget for the harness scheduler. `1` (default) is
# serial behavior. `auto` resolves to `nproc / max(tool_thread_curves)`
# so each task saturates its own thread budget without oversubscription.
# Integers > 1 cap the pool at that size. See crates/harness/src/scheduler.rs.
SWFC_HARNESS_CONCURRENCY=1

# Validation-lane parallelism (numeric 0/1). `1` = primary executor
# advances processing/analysis tasks while a secondary executor
# independently runs any ready validate_* task. `0` (or any other
# value) keeps validators serial. Overrides SWFC_HARNESS_CONCURRENCY
# when set to `1`. True parallel execution requires
# SWFC_EXECUTOR_MODE=local; aws/slurm keep the lane picker correctness
# but serialise execution through one backend handle (avoids
# double-provisioning a remote instance / submitting two batch jobs
# for one logical lane).
SWFC_HARNESS_VALIDATION_LANE=1

# Harness loop tuning (advanced — leave at defaults unless diagnosing).
# - SWFC_HARNESS_AMEND_CANCEL=1 kills an in-flight task whose stage was
#   just amended, instead of letting it finish (default off; finishing
#   the prior attempt is usually cheaper than re-running from scratch).
# - SWFC_HARNESS_SETTLE_SECS controls the quiet period the harness
#   waits between iterations after a task completes (default 1s; bump
#   on slow filesystems where the agent's output write isn't visible
#   to the harness scanner immediately).
# - SWFC_HARNESS_BATCH_WINDOW_SECS — chat-side debounce window before
#   the HarnessBatcher flushes accumulated harness-progress events as
#   one synthetic assistant turn (default 10s; out-of-range / 0 /
#   non-numeric values fall back to default; values >600 are rejected
#   so blockers stay visible).
# - SWFC_TASK_HEARTBEAT_STALL_SECS — heartbeat stall threshold
#   (default 300 = 5 min, per DEFAULT_TASK_HEARTBEAT_STALL_SECS in
#   crates/core/src/config.rs:57; set 0 to disable). On breach the
#   harness flips the Running task to Blocked { HeartbeatStalled }.
# - SWFC_HEARTBEAT_LIVENESS_SECS — orphan-by-crash recovery liveness
#   window (default 60s, clamped [0, 600]).
# - SWFC_HARNESS_FINALIZE_PROBE_MIN_INTERVAL_SECS / _TIMEOUT_SECS —
#   finalize-probe cadence + per-probe deadline for silent-completion
#   detection (defaults 30s / 10s).
# - SWFC_RUNTIME_MULTIPLIER — multiplier on a task's expected_secs
#   budget before the scheduler trips a BlockerKind::TimeExceeded
#   (default 3.0).
# SWFC_HARNESS_AMEND_CANCEL=1
# SWFC_HARNESS_SETTLE_SECS=1
# SWFC_HARNESS_BATCH_WINDOW_SECS=10
# SWFC_TASK_HEARTBEAT_STALL_SECS=300
# SWFC_HEARTBEAT_LIVENESS_SECS=60
# SWFC_HARNESS_FINALIZE_PROBE_MIN_INTERVAL_SECS=30
# SWFC_HARNESS_FINALIZE_PROBE_TIMEOUT_SECS=10
# SWFC_RUNTIME_MULTIPLIER=3.0

# Bypass the harness multi-process flock (RC-22). The harness refuses
# to start when another harness holds the per-session flock at
# ~/.scripps-workflow/locks/<session_id>.lock (exit code 2). Setting
# =1 lets a second harness attach — concurrent harnesses race on the
# dispatch WAL, so tests only.
# SWFC_HARNESS_DEBUG_ALLOW_MULTI_PROCESS=1

# Preserve per-task scratch directories (runtime/scratch/<task_id>/)
# on Completed / Failed transitions for forensic debugging. Default
# off (the cleanup runs as soon as the task reaches a terminal state).
# SWFC_SCRATCH_KEEP=1

# Per-agent-invocation guardrails honored by all three agent wrappers.
# - SWFC_AGENT_MEMORY_CAP_GB=<n>: per-agent memory ceiling. Unset = no
#   cap. When set, agent-claude.sh wraps the host-path `claude`
#   subprocess tree in `systemd-run --user --scope -p MemoryMax=<n>G`
#   (falls back to `prlimit --as`); docker/apptainer paths add
#   `--memory=<n>g`. Only the agent cgroup is reaped on breach;
#   harness/server/dev UIs stay alive.
# - SWFC_AGENT_WALLCLOCK_SECS=<n>: per-agent wallclock cap. Unset =
#   no cap. The harness kills the agent subprocess group at the
#   deadline and flips the task to Blocked { TimeExceeded }.
# - SWFC_AGENT_CMD=<path>: override the agent executable (default
#   ./scripts/agent-claude.sh). Used by integration tests +
#   alternative-agent experiments.
# - SWFC_AGENT_SCRIPT=<path>: eval-adapters alias for SWFC_AGENT_CMD.
#   Honoured by crates/eval-adapters/* runners; identical semantics.
# - SWFC_DISABLE_BLAS_PRELOAD=1: opt out of the libopenblas LD_PRELOAD
#   interpose for sites whose R install ships a parallel libRblas
#   natively (Conda forge R, MKL-built builds).
SWFC_AGENT_MEMORY_CAP_GB=64
SWFC_AGENT_WALLCLOCK_SECS=14400
# SWFC_AGENT_CMD=./scripts/agent-claude.sh
# SWFC_DISABLE_BLAS_PRELOAD=1

# Dynamic per-agent resource allocation. Default ON. When active, each
# agent's SWFC_HW_VCPUS_AVAILABLE / SWFC_HW_MEMORY_GB envelope reflects
# the host's live free budget minus an overhead reserve, split across
# concurrent picks proportional to their per-stage high-water
# requirements (compute_high_water in executor/sizing.rs). Set to 0 to
# revert to the legacy "agent sees the full host" envelope.
SWFC_HW_DYNAMIC_ALLOCATION=1

# Overhead margin held back from agents for the harness, server, UI,
# and OS. The larger of (absolute, pct of total) wins per dimension.
# Defaults: 1 vCPU, 2 GB, 10%. SWFC_HW_OVERHEAD_PCT is capped at 50.
SWFC_HW_OVERHEAD_VCPUS=1
SWFC_HW_OVERHEAD_MEMORY_GB=2
SWFC_HW_OVERHEAD_PCT=10

# Advisory CPU/thread floor from remediation or site policy. The agent
# bootstrap applies it to BLAS/OpenMP thread env vars and container
# `--cpus`. Unset = use scheduler's recommended thread count.
# SWFC_HW_NPROC_HINT=8

# Note: SWFC_HW_VCPUS_AVAILABLE / SWFC_HW_MEMORY_GB / SWFC_HW_GPU /
# SWFC_HW_RECOMMENDED_THREADS / SWFC_HW_TOOL_THREAD_CURVES /
# SWFC_HW_TASK_RESOURCE_CLASS / SWFC_HW_CONCURRENT_PEERS_BY_CLASS /
# SWFC_HW_INTAKE_FACTS / SWFC_HW_ENV_OVERRIDES / SWFC_HW_GPU_CAPABILITY_REF
# are RUNTIME-SET by the harness onto each agent's env at dispatch.
# Setting them in your shell will be silently overwritten — only override
# when reproducing a specific allocation in isolation.

# =============================================================================
# Pilot sizing
# =============================================================================
# Runs a small pilot against representative tasks before the main
# provisioning call, then feeds the projected high-water requirements
# into local allocation, AWS instance selection, and SLURM class
# selection. AWS defaults pilot on; local/SLURM require explicit opt-in
# and SLURM consumes an existing report when present.

# Gate for the pilot pathway. Default: 1 on AWS, 0 elsewhere.
# SWFC_PILOT_ENABLED=1

# Number of pilot tasks to sample before projecting. Default: 3.
# SWFC_PILOT_TASKS=3

# Multiplier applied to the pilot's measured high-water when projecting
# the full-run shape. Default: 1.5.
# SWFC_PILOT_MULTIPLIER=1.5

# Pilot instance type override. When set, the pilot runs on this shape
# regardless of DAG contents (useful for forcing a cheap shape like
# t3.medium). Cleared after pilot release.
# SWFC_PILOT_INSTANCE=t3.medium

# Measurement interval during the pilot (seconds). Default: 5.
# SWFC_PILOT_INTERVAL_SECS=5

# Long-form aliases accepted by the pilot config loader. Short names
# above remain canonical.
#   SWFC_PILOT_INSTANCE_TYPE              ≡ SWFC_PILOT_INSTANCE
#   SWFC_PILOT_TASK_COUNT                 ≡ SWFC_PILOT_TASKS
#   SWFC_PILOT_PROJECTION_MULT            ≡ SWFC_PILOT_MULTIPLIER
#   SWFC_PILOT_MEASUREMENT_INTERVAL_SECS  ≡ SWFC_PILOT_INTERVAL_SECS
# SWFC_PILOT_INSTANCE_TYPE=t3.medium
# SWFC_PILOT_TASK_COUNT=3
# SWFC_PILOT_PROJECTION_MULT=1.5
# SWFC_PILOT_MEASUREMENT_INTERVAL_SECS=5

# =============================================================================
# Stall monitor — opt-in (default on for AWS; off elsewhere)
# =============================================================================
# Samples CPU/memory/GPU from /proc/<pid>/ (local) or CloudWatch (AWS)
# and emits a StallSignal when a threshold is breached. The harness
# translates signals into Blocked { Stalled } sessions.

# Gate for the stall monitor. Defaults to on when SWFC_EXECUTOR_MODE=aws,
# off otherwise. Accepts 1/0/true/false.
SWFC_STALL_ENABLED=1

# CPU below this percentage counts as starvation. Default: 5.0.
# SWFC_STALL_CPU_MIN_PCT=5.0

# Sustained CPU-starvation duration before a stall signal fires (minutes).
# Default: 30.
# SWFC_STALL_CPU_WINDOW_MINS=30

# Memory above this percentage counts as pressure. Default: 90.0.
# SWFC_STALL_MEM_MAX_PCT=90.0

# Sustained memory-pressure duration before a stall signal fires (minutes).
# Default: 5.
# SWFC_STALL_MEM_WINDOW_MINS=5

# GPU-idle threshold while the envelope declares training (minutes).
# Default: 15.
# SWFC_STALL_GPU_IDLE_MINS=15

# Multiplier on expected task runtime before a runtime-overrun signal
# fires. Default: 3.0.
# SWFC_STALL_RUNTIME_MULT=3.0

# Sampling cadence (seconds). Default: 30. CloudWatch native granularity
# caps at 60s.
# SWFC_STALL_SAMPLE_INTERVAL_SECS=30

# =============================================================================
# Chat server → harness dispatch
# =============================================================================
# URL the harness POSTs progress events back to. Must match the chat
# server's actual listening port (the server's `--port` flag, default
# 3000). A mismatch silently breaks the UI's harness-progress events
# because the SSE bus never receives the POSTs (the harness logs
# `Connection refused` after retries) — WORKFLOW.json still updates,
# but the "running" pill in the inspector never lights up.
#
# The canonical dev port is 3000 across:
#   - `crates/server/src/lib.rs` `--port` default
#   - Makefile `DEV_SERVER_PORT`
#   - `ui/vite.config.ts` VITE_API_PORT fallback
# The `dev_port_drift` test (crates/server/tests/dev_port_drift.rs)
# fails CI if these three drift apart. Default: http://127.0.0.1:3000.
SWFC_SERVER_URL=http://127.0.0.1:3000

# Vite reads this and uses it as the `/api/*` proxy target for the
# dev UI server. Must match SWFC_SERVER_URL's port above; the
# Makefile's `make up` recipe exports it automatically to keep the
# vite proxy and the server's `--port` aligned. Default: 3000.
VITE_API_PORT=3000

# Per-IP global rate-limit (tower-governor). Production defaults from
# crates/server/src/lib.rs are 2000ms interval / burst 30 → 0.5 req/s
# sustained — fine for proxied prod traffic where each SME is a
# distinct peer IP. In LOCAL DEV every UI session shares 127.0.0.1
# and the UI polls /dag, /proposals, /dispositions, /compose-outcome,
# /metrics every few seconds; that burns through the 30-token burst
# within a single chat turn and 429s the polling endpoints. The
# source comment at crates/server/src/lib.rs:240 explicitly
# recommends these dev overrides.
SWFC_RATE_LIMIT_INTERVAL_MS=10
SWFC_RATE_LIMIT_BURST=10000

# Absolute path to the scripps-workflow-harness binary. The chat server
# spawns this as a subprocess for post-emit execution. Default: resolved
# via `which scripps-workflow-harness`.
# SWFC_HARNESS_BIN_PATH=/usr/local/bin/scripps-workflow-harness

# Default agent script the chat server passes as --agent when spawning
# the harness. Operators set this to the path of agent-claude.sh /
# agent-claude-aws.sh / agent-claude-slurm.sh. Default: ./scripts/agent-claude.sh
# SWFC_DEFAULT_AGENT_PATH=./scripts/agent-claude.sh

# Override the agent-scripts root for path-jail validation. Default
# ./scripts/. The server refuses to spawn an --agent that doesn't
# resolve under this directory.
# SWFC_SCRIPTS_DIR=./scripts

# Server-side default for harness `--max-iterations` when the chat
# server spawns it via /start-execution. Default: 20. Bump to e.g.
# 1000 for long-running detached compute so the harness lives across
# the workload instead of churning at iteration boundaries. The
# standalone `make ivd-execute` Make target reads its own MAX_ITER
# knob (default 30) and does NOT honor this variable.
SWFC_DEFAULT_MAX_ITERATIONS=20

# =============================================================================
# SLURM provisioning — required when SWFC_EXECUTOR_MODE=slurm
# =============================================================================
# See docs/remote-compute-operator-reference.md#slurm-backend and
# docs/2026-04/slurm-remote-compute-plan-2026-04-18.md for the full design.
# Every var below is no-op when SWFC_EXECUTOR_MODE=local|aws.
#
# Transport: system `ssh` + `rsync` via duct (ControlMaster multiplexing).
# Cost model: NoopCostModel — HPC fairshare/QoS quotas, not $/hr.

# Login/submit node hostname. REQUIRED.
# SWFC_SLURM_HOST=login.cluster.example.org

# Shared-FS path on the cluster where packages + wrappers get staged.
# REQUIRED. Typical: /scratch/$USER/scripps
# SWFC_SLURM_STAGING_DIR=/scratch/alan/scripps

# Fallback partition when the sizing mapping has nothing that fits.
# REQUIRED. Also used when the operator doesn't ship a slurm-mapping.yaml.
# SWFC_SLURM_DEFAULT_PARTITION=normal

# SSH user. Defaults to the shell's `$USER` via `ssh`'s own fallback.
# SWFC_SLURM_USER=alan

# Private key path. Omit to let `ssh` use ssh-agent / default keys.
# SWFC_SLURM_SSH_KEY=~/.ssh/id_ed25519_cluster

# Bastion host (`ssh -J <host>` flag). Omit for direct SSH.
# SWFC_SLURM_PROXY_JUMP=bastion.corp.example.org

# Billing / project account (`#SBATCH --account=`). Omit when the site
# derives it from the user.
# SWFC_SLURM_ACCOUNT=lotz-lab

# Default QoS (`#SBATCH --qos=`). Overridden per-class when a
# resource_class specifies its own qos in slurm-mapping.yaml.
# SWFC_SLURM_DEFAULT_QOS=normal

# Comma-separated `module load` list prepended to every sbatch script
# body. Leave unset when the site's default environment is sufficient.
# SWFC_SLURM_MODULES=python/3.11,singularity/3.8

# `sacct` poll rate (seconds). Default: 20. Lower wastes SSH round-trips;
# higher delays staleness detection.
# SWFC_SLURM_POLL_INTERVAL_SECS=20

# Abort + scancel a job that's still PENDING after this many seconds.
# Default: 21600 (6 hours).
# SWFC_SLURM_MAX_QUEUE_WAIT_SECS=21600

# Fallback `--time=` when the sizing mapping's resolver falls back
# (no named resource_class satisfied the requirement). Default: 04:00:00.
# SWFC_SLURM_DEFAULT_TIME_LIMIT=04:00:00

# Container runtime for the SLURM agent wrapper (agent-claude-slurm.sh).
# Accepted: singularity | apptainer | podman. Unset = agent runs on the
# host's Python/R/etc. directly. Sites that enforce rootless containers
# on compute nodes should pick one here.
# SWFC_SLURM_CONTAINER_RUNTIME=singularity

# Concurrent CPU-class task budget on the SLURM lane. Default 1 (serial).
# Bump to fan out independent CPU tasks across multiple sbatch
# submissions in parallel.
# SWFC_SLURM_MAX_PARALLEL_TASKS=1

# Concurrent GPU-class task budget. Default 0 (refuse GPU tasks on the
# SLURM lane entirely). Set to a positive value to permit GPU dispatch
# up to that ceiling; the resource_class → partition mapping must
# also resolve.
# SWFC_SLURM_MAX_GPU_TASKS=0

# Emit per-job sacct usage stats on completion (cputime, MaxRSS, etc.)
# into runtime/slurm-usage.json. Default off; opt in for capacity
# planning runs.
# SWFC_SLURM_EMIT_USAGE=1

# =============================================================================
# Container mode (Stage 15) — local agent
# =============================================================================
# Operator-level default container image used by scripts/agent-claude.sh
# when neither the per-task `container.image` field nor the package's
# policies/container.json::image is set. Per-task and package-level
# pins still win — this is the lowest-priority source. With this set,
# every agent invocation runs inside the named image by default; unset
# (or set to empty) to fall back to host execution.
#
# `bio-min:local` (built by scripts/build-bio-min.sh) ships R 4.5 +
# Python 3.11 + numpy/pandas/scipy + OpenBLAS + OpenMP + TBB + OpenMPI
# + samtools/bcftools/STAR/salmon/GATK4/fastqc + Node + claude-code CLI
# so the dispatched agent can `apt install` / `pip install` /
# `Rscript -e 'BiocManager::install("…")'` whatever analysis package
# the SME-confirmed method requires at runtime.
# The older `scripps-workflow-agent:local` baseline shipped only
# Python+pip+node and forced agents to reimplement DESeq2 etc. in
# pure Python (2026-05-24 S1 finding).
SWFC_DEFAULT_CONTAINER_IMAGE=bio-min:local

# Pin the local-host runtime (skip the apptainer → docker → podman
# auto-probe). Accepted: apptainer | docker | podman. Unset = harness
# probes apptainer → docker → podman in priority order.
SWFC_CONTAINER_RUNTIME=docker

# Per-session container cache mount root. Default: ~/.scripps-workflow/
# agent-cache/<session_id>. Set to a directory on a high-capacity volume
# when running on a host whose system disk is small.
SWFC_AGENT_CACHE_DIR=/mnt/big/swfc-agent-cache

# Per-task scratch mount root. Default: <package>/runtime/scratch/<task_id>/.
# Override when the package volume is too small for large intermediates.
SWFC_AGENT_SCRATCH_DIR=/mnt/big/swfc-scratch

# Soft ceiling on per-session cache size (default 50 GB).
SWFC_AGENT_CACHE_MAX_GB=50

# LRU cache-eviction sweep cadence (seconds). Default 600 (10 min);
# clamped to [60, 3600]. Out-of-range or non-numeric values fall back
# to default with a stderr warning.
# SWFC_CACHE_EVICTION_PERIOD_SECS=600

# Opt out of the per-session cache mount entirely.
# SWFC_AGENT_CACHE_DISABLE=1

# Share the agent cache (pip/conda/R-libs) ACROSS sessions instead of
# the default per-session subdir. Default = 0 (per-session isolation,
# prevents cross-session cache poisoning per D-R13). Setting = 1
# switches the cache layout to a single shared `agent-cache/global/`
# directory so a heavy compile (e.g. DESeq2 from Bioconductor,
# 15-30 min the first run) installs once and is reused by every later
# session that picks the same method. Designed for testing campaigns +
# dev environments; production deployments should leave it off so
# session isolation holds. Per-package R/Python installs are atomic
# (tmp + rename), so concurrent agents installing the same package
# don't corrupt each other.
# SWFC_AGENT_CACHE_GLOBAL=1

# Per-task background credential refresh interval (seconds). The agent
# script polls $HOME/.claude/.credentials.json and re-copies it into
# the per-session bind-mount when the host is newer, so an operator
# `claude /login` to a different account propagates to in-flight
# agents within this window. Default 15. Set to 0 to disable. Values
# <5 or non-numeric clamp to default with a stderr warning.
SWFC_AGENT_CRED_REFRESH_SECS=15

# Per-session @anthropic-ai/claude-code version. The container image's
# baked-in claude CLI lags Anthropic's deployed minor version
# (e.g. 2.1.131 in image vs 2.1.132 on host); older minors get
# silently 429'd on /v1/messages with no stderr. The agent script
# npm-installs the requested version into the per-session cache
# (~30s one-time per session) and bind-mounts it into the container,
# preempting the image's bundled binary via PATH. Default `latest`.
SWFC_AGENT_CLAUDE_VERSION=latest

# Force re-install on every dispatch (default 0 = reuse the cached
# install for the lifetime of the session). Set to 1 to pick up new
# Anthropic releases mid-session without restarting.
# SWFC_AGENT_CLAUDE_FORCE_REINSTALL=1

# Opt out of the per-session install entirely; falls back to the
# container's baked-in claude. Use only when the image was just
# rebuilt with a known-good claude-code or when the host has no npm.
# SWFC_AGENT_CLAUDE_DISABLE=1

# Local-mode sandbox layer. Default: off. With `bubblewrap`, the
# host-mode agent invocation is wrapped in `bwrap` for filesystem +
# network containment without container overhead. Requires `bwrap` on
# PATH; falls back to unsandboxed host with a stderr warning.
# SWFC_LOCAL_SANDBOX=bubblewrap

# Fallback network policy when the atom's `ContainerSpec.network` is
# unset. Default: bridge. Use `none` to drop networking inside
# containers/sandboxes (offline analysis runs).
# SWFC_CONTAINER_NETWORK_DEFAULT=bridge

# Opt-in for the Wave / Seqera on-demand image build resolver (S15.13).
# SWFC_WAVE_RESOLVER=1

# Bearer token for the digest-resolver against private registries.
# SWFC_CONTAINER_REGISTRY_AUTH=<token>

# When 1 (default), AwsExecutor refuses dispatches whose
# `preferred_container` requires a runtime newer than the AMI's baked
# RUNTIME_VERSIONS.json. Set to 0 only on hosts where you intentionally
# bypass the strict gate.
# SWFC_AMI_RUNTIME_STRICT=1

# Extends `verify-reproducibility` to re-resolve emitted ContainerSpec
# digests against the registry.
# SWFC_CONTAINER_VERIFY=1

# Opt-in for SLURM 25.11's --container directive (off by default;
# honored only when the detected SLURM is ≥ 25.11).
# SWFC_SLURM_NATIVE_CONTAINER=1

# Kill switch: Stage 15 container plumbing is bypassed entirely.
# Falls through to host environment path (no runtime probe, no image
# pull). Use when a host has no runtime and the SME accepts the lower
# reproducibility floor.
# SWFC_DISABLE_CONTAINERS=1

# Toggle Syft SBOM emit at task completion. Default: 1. Set to 0 to
# skip the supply-chain attestation step when Syft is unavailable or
# the site doesn't require SBOMs.
# SWFC_SBOM_EMIT=0

# Toggle the libRblas LD_PRELOAD interpose performed by the
# _agent-blas-bootstrap.sh helper. Set to 1 to OPT OUT of the
# interpose on sites whose R install ships a parallel libRblas
# natively (Conda forge R, MKL-built builds). Default: off (preload on).
# SWFC_DISABLE_BLAS_PRELOAD=1

# Override path to the mock claim-emitter binary used by the
# contract-adequacy adapter. Default: scripts/agent-mock-claim-emitter.sh
# SWFC_AGENT_MOCK_CLAIM_EMITTER=/path/to/custom-claim-emitter.sh

# Agent log rotation cap (bytes). When the agent's output log exceeds
# this size, agent-claude.sh rotates it. Default 209715200 (200 MiB);
# set 0 to disable rotation.
# SWFC_AGENT_LOG_MAX_BYTES=209715200

# Agent heartbeat cadence (seconds). Default 30.
# SWFC_HEARTBEAT_INTERVAL_SECS=30

# Memory high-water percentage. The agent trips an early warning when
# its memory exceeds MEM_MAX_MB × SWFC_AGENT_MEMORY_HIGH_WATER_PCT / 100.
# Default 85.
# SWFC_AGENT_MEMORY_HIGH_WATER_PCT=85

# Credential-rotation grace window (seconds). When the agent script
# refreshes Claude credentials, it skips host→container copy if the
# container-side file's mtime advanced within this many seconds.
# Default 2.
# SWFC_AGENT_CRED_ROTATION_GRACE_SECS=2

# Docker run hardening (consumed by scripts/agent-claude*.sh wrappers).
# All have safe defaults from scripts/agent-claude-common.sh:
#   SWFC_DOCKER_TMPFS_TMP_SIZE     /tmp tmpfs size           (default 1g)
#   SWFC_DOCKER_TMPFS_VARTMP_SIZE  /var/tmp tmpfs size       (default 512m)
#   SWFC_DOCKER_PIDS_LIMIT         --pids-limit              (default 2048)
# SWFC_DOCKER_TMPFS_TMP_SIZE=1g
# SWFC_DOCKER_TMPFS_VARTMP_SIZE=512m
# SWFC_DOCKER_PIDS_LIMIT=2048

# Library version pins (SWFC_LIB_PIN_<NAME>=<version>). Every var
# matching this prefix is forwarded into the agent's environment and
# read by the install-proxy to pin a specific library version.
# Examples:
#   SWFC_LIB_PIN_SCANPY=1.9.6
#   SWFC_LIB_PIN_ANN_DATA=0.10.0
#   SWFC_LIB_PIN_BLAS=openblas-0.3.27
#   SWFC_LIB_PIN_BWA=0.7.17

# Bypass the agent sandbox environment-clearing pass. Default off (the
# harness clears all but allowlisted vars before invoking the agent).
# With =1 the agent inherits the full parent environment — debug only;
# leaks secrets that the clearing pass is precisely there to scrub.
# SWFC_DISABLE_ENV_CLEAR=1

# =============================================================================
# Derived-image warm-up (Plan §S15.x — local agent)
# =============================================================================
# When the compiler emits a buildable runtime-prereqs manifest
# (policies/runtime-prereqs.json + runtime/derived-image.Dockerfile),
# the local-executor pre-flight runs scripts/build-derived-image.sh
# before the first agent dispatch. The script content-hashes the
# manifest, checks the local docker registry for a cached
# scripps-derived:<hash> image, and either re-uses it (cheap) or
# builds it fresh.

# Skip the local-cache check and always rebuild. Use after a base-image
# upgrade or while debugging the renderer.
# SWFC_FORCE_IMAGE_REBUILD=1

# Buildkit cache root for derived-image layer reuse across sessions.
# Default: $SWFC_AGENT_CACHE_DIR/buildkit if SWFC_AGENT_CACHE_DIR is
# set, else ~/.scripps-workflow/buildkit-cache.
SWFC_BUILDX_CACHE_DIR=/mnt/big/swfc-agent-cache/buildkit

# Wall-clock cap on a single derived-image build. Default 1800 (30 min).
# Exceeding it surfaces as a typed BlockerKind::ImageBuildFailed.
SWFC_IMAGE_BUILD_TIMEOUT_SECS=1800

# Image-tag prefix for derived images. Default: scripps-derived. Set
# to a private-registry path like "registry.example.com/scripps/derived"
# when pre-pushing for cluster reuse.
# SWFC_DERIVED_IMAGE_TAG_PREFIX=scripps-derived

# Override the path to the build-derived-image.sh helper (default
# `scripts/build-derived-image.sh` resolved relative to the harness CWD).
# SWFC_IMAGE_BUILDER_PATH=/usr/local/bin/build-derived-image.sh

# Per-atom isolated derived images keyed by content_hash_from_file.
# Default on (1). With =0 the harness reverts to the legacy union-build
# path that bakes every prereq into one image. Flip off only when
# debugging a per-task image build failure.
SWFC_PER_TASK_IMAGES=1

# Per-atom image build directory. Default ~/.scripps-workflow/per-atom-builds/.
# Point at a high-capacity volume when running large fan-outs.
# SWFC_PER_ATOM_BUILD_ROOT=/mnt/big/swfc-per-atom-builds

# Override the install-proxy library path. The emitter normally walks
# up from CWD looking for lib/install-proxy/. Set when running outside
# the repo checkout.
# SWFC_INSTALL_PROXY_LIB=/opt/scripps/lib/install-proxy

# Per-task provisioning policy JSON path. The harness stamps this onto
# every dispatch envelope so the agent script can enforce atom safety
# policy + container plumbing. Default
# /etc/scripps-workflow/provisioning.json (falls back to the
# package-local policies/provisioning-policy.json when absent).
# SWFC_PROVISIONING_POLICY=/etc/scripps-workflow/provisioning.json

# Bypass install-proxy provisioning policy check inside the agent.
# Debug-only — the check gates implicit `pip install` / `apt-get install`.
# SWFC_PROVISIONING_DISABLE=1

# Skip the shim smoke-test that build-derived-image.sh runs after each
# successful build (verifies install-proxy + LD_PRELOAD shim load).
# SWFC_SKIP_SHIM_SMOKE=1

# =============================================================================
# Test / script knobs
# =============================================================================
# Opt-in flag for Make targets that hit the live Anthropic API
# (ivd-chat-llm, ivd-web-execute). When unset, those targets SKIP with a
# pointer to the mock variant. Gate added 2026-04-20 per
# docs/2026-04/token-burn-remediation-plan-2026-04-20.md Phase 2.
SWFC_LIVE_API=1

# Enable the Haiku-powered session auto-title feature (§3.15 / Workstream H,
# landed 2026-04-21). `=1` surfaces the "Auto-name" button in the UI title
# bar and enables POST /api/chat/session/:id/auto-title. One Haiku 4.5 call
# per session lifetime (~$0.0006, billed to `side_call_cost_usd`);
# idempotent — once set, the route short-circuits without re-invoking the
# LLM. Unset = feature off (button hidden, route returns 503).
SWFC_AUTO_TITLE=1

# Preserve test output packages under /tmp/scripps-*-latest symlinks so you
# can inspect them after `make ivd*` runs.
# KEEP_PACKAGE=1

# Iteration cap for `make ivd-execute`. Default: 30.
# MAX_ITER=30

# Fixture-runner latency budget (ms). `make latency-baseline` gates on this.
# Default: 8000.
# SWFC_FIXTURE_TIMEOUT_MS=8000

# Port for `scripts/test-ivd-web-execute.sh`. Default: 3737.
# SWFC_TEST_PORT=3737

# Enable Playwright live-API tier. `=1` boots the real server + UI and runs
# every `e2e/tests/live/**` spec; otherwise those specs skip. Also requires
# SWFC_ANTHROPIC_API_KEY. See e2e/playwright.config.ts.
# PLAYWRIGHT_LIVE=1

# Attach the `ivd-observer.live.spec.ts` Playwright spec to an existing
# session rather than creating a fresh one. Used to watch a long-running
# lotz calibration in-flight without restarting intake.
# SWFC_OBSERVE_SESSION=abcd-1234-ef56

# SME backend selector for live Playwright specs
# (e2e/helpers/smeBackend.ts + ivd-full-lifecycle-headed.live.spec.ts).
#   scripted — fixture-driven (default; no API key needed)
#   fm       — Anthropic-backed FM SME (requires SWFC_ANTHROPIC_API_KEY
#              or legacy ANTHROPIC_API_KEY)
# SWFC_SPEC_SME_MODE=fm

# e2e supervisor harness (e2e/supervisor.mjs) inputs. The supervisor
# wraps a live Playwright run with a safety gate that refuses to
# auto-advance unless explicitly told to.
#   SWFC_SUPERVISOR_SESSION_ID  target session UUID         (required)
#   SWFC_SUPERVISOR_PKG_DIR     emitted package directory   (required)
#   SWFC_SUPERVISOR_OUT_DIR     supervisor output directory (required)
#   SWFC_SUPERVISOR_BASE_URL    chat-server URL             (default http://127.0.0.1:3737)
#   SWFC_SUPERVISOR_FORCE_AUTO  skip safety gate (=1; DESTRUCTIVE)
# SWFC_SUPERVISOR_SESSION_ID=
# SWFC_SUPERVISOR_PKG_DIR=
# SWFC_SUPERVISOR_OUT_DIR=
# SWFC_SUPERVISOR_BASE_URL=http://127.0.0.1:3737
# SWFC_SUPERVISOR_FORCE_AUTO=1

# Probe output directory for e2e/dark-mode-drawer-probe.mjs. The
# baked-in default is an alan-specific path
# (/home/a/mounts/wadmin/home/a/swfc-e2e-results/dark-mode-drawer-probe)
# — set this when running on any other host.
# SWFC_PROBE_OUT_DIR=/tmp/swfc-dark-mode-probe

# Mock-agent fixture knob. When `true`, scripts/agent-mock-blocker.sh
# forces a discover_* task to Blocked so the fixture-runner tests the
# blocker path without touching real data. Test-only — do not set in
# production.
# SWFC_MOCK_DISCOVERY_BLOCK=true

# =============================================================================
# Plotting library overrides
# =============================================================================
# Override the path to the shared Python plotting library (lib/plotting/).
# The emitter normally walks up from CWD looking for lib/plotting/core.py;
# set this when running outside the repo checkout.
# SWFC_PLOTTING_LIB=/opt/scripps/lib/plotting

# Analogous override for the R plotting library used by R-renderer atoms.
# SWFC_PLOTTING_R_LIB=/opt/scripps/lib/plotting-r

# Pinned R version surfaced into emitted plotting tasks. Mirrored by the
# plotting_version_sync test gate. Default: tracked in core::emitter.
# SWFC_PLOTTING_R_VERSION=4.4.1

# Override the default plot-preset id when emitting figure-resolver
# scaffolds. Consumed by the plotting smoke harness only.
# SWFC_PLOT_PRESET=default

# =============================================================================
# Telemetry / OpenTelemetry
# =============================================================================
# tracing_subscriber output format. json emits structured logs the
# collector picks up directly. Default: text.
# SWFC_LOG_FORMAT=json

# =============================================================================
# Dev sandbox paths (Makefile-driven `make dev-*` targets)
# =============================================================================
# The Make `dev-*` targets point the chat server at separate session/
# upload/package roots so a dev run doesn't trample production session
# data on the same machine.
# SWFC_DEV_STORAGE_ROOT=$HOME/.scripps-dev
# SWFC_DEV_SESSIONS_DIR=$HOME/.scripps-dev/sessions
# SWFC_DEV_UPLOAD_ROOT=$HOME/.scripps-dev/uploads
# SWFC_DEV_PACKAGE_ROOT=$HOME/.scripps-dev/packages
# SWFC_DEV_AGENT_CACHE_DIR=$HOME/.scripps-dev/agent-cache
# SWFC_DEV_AGENT_SCRATCH_DIR=$HOME/.scripps-dev/agent-scratch
# SWFC_SESSION_CACHE_DIR=$HOME/.scripps-dev/session-cache

# =============================================================================
# Doc-gate + repo hygiene
# =============================================================================
# When 1, scripts/check-env-vars-documented.sh exits non-zero on drift
# (every SWFC_* in source must be documented in CLAUDE.md or
# docs/env-vars-reference.md). Default 0 (warn-only).
# SWFC_DOC_GATE_STRICT=1

# Scope selector for scripts/check_repo_hygiene.sh. Default: full.
# SWFC_HYGIENE_SCOPE=quick

# Drift-mode for scripts/check-modality-manifest-drift.sh. Default warn;
# CI flips to fail once the legacy keyword file is deleted (planned per A.S5).
# SWFC_MODALITY_DRIFT_MODE=fail

# ECAA emit-time schema validation. When 1, crates/conversation/src/emit/
# validation.rs returns Err on any ECAA-sidecar schema-validation failure,
# propagating through emit_package to fail the calling test or request.
# When unset / 0, validation runs and reports but mismatches are warn-only
# (production default). CI sets this to 1 workflow-level in
# .github/workflows/rust.yml, and `make test` exports it locally, so any
# schema drift fails a PR run instead of landing silently. Production
# deployments leave it unset so a single drifted package never blocks an
# SME's session — the validation report is still written for review.
# SWFC_VALIDATION_BLOCK_ON_FAIL=1

# =============================================================================
# Evaluation / benchmarking (crates/eval-baselines + crates/eval-adapters)
# =============================================================================
# None of these are read by the production server; they gate the
# value-add evaluation harness and pin output paths for offline runs.

# Output roots.
SWFC_EVAL_RUNS_DIR=$HOME/.scripps-eval/runs
SWFC_EVAL_CACHE_DIR=$HOME/.scripps-eval/cache
SWFC_METRICS_SNAPSHOT_DIR=$HOME/.scripps-eval/metrics-snapshots
# SWFC_SCORECARDS_DIR=runtime/scorecards

# Eval harness tuning.
# SWFC_EVAL_MAX_TASKS=100
# SWFC_EVAL_THROTTLE_BACKOFF_SECS=2

# Benchmark / external corpora.
SWFC_BENCHMARK_DATA_DIR=$HOME/.scripps-eval/benchmark-data
# SWFC_BIOMNI_PYTHON=/opt/biomni/bin/python
# SWFC_LONG_ARC_PACKAGE_DIR=$HOME/.scripps-eval/long-arc-packages
# SWFC_PACKAGE_DIR=$HOME/.scripps-eval/inspect-package

# Per-tier live-API gates + cost caps. =1 routes through live APIs;
# unset = use mock fixtures.
# SWFC_BUCKET_A_LIVE=1
# SWFC_BUCKET_A_COST_CAP_USD=10
# SWFC_BUCKET_A_DOCS_BASELINE=baseline-id
# SWFC_TIER_2_5_REAL_AGENT=1
# SWFC_TIER_7_4_HARNESS_RUNS=3
# SWFC_TIER_17_3_LIVE=1
# SWFC_TIER_17_3_PORT=19173
# SWFC_TIER_19_1_LIVE=1
# SWFC_TIER_19_2_LIVE=1
# SWFC_TIER_19_3_LIVE=1

# Live-mode gates for external-eval smoke wrappers
# (scripts/smoke-biomni.sh, scripts/smoke-biomedagent.sh). Default off
# — the runners emit RunnerSkipped without these.
# SWFC_BIOMNI_LIVE=1
# SWFC_BIOMEDAGENT_LIVE=1

# Biomni smoke-test input/output paths.
# SWFC_BIOMNI_SMOKE_INTAKE=testdata/wrroc-fixtures/01-encode-ctcf-k562/intake.json
# SWFC_BIOMNI_SMOKE_OUT=runtime/smoke-biomni

# Modality-stratum YAML override for eval-baselines.
# SWFC_STRATA_YAML=/path/to/custom-strata.yaml

# Backend selector for eval-baselines runners
# (crates/eval-baselines/src/runners/). Set per-arm by the harness;
# accepted values: biomni, biomedagent, scripps. Do not normally set
# in a shell.
# SWFC_AGENT_BACKEND=biomni

# Emit a warning row in scripts/audit-emitted-dag.py output when ECAA
# sidecars fail their schema checks. Independent from
# SWFC_VALIDATE_ON_EMIT (which runs at emit time inside the server).
# SWFC_VALIDATE_ECAA=1

# Determinism harness overrides.
# SWFC_DETERMINISM_BIN=/path/to/custom-differ
# SWFC_DETERMINISM_LIVE=1

# Aggregator debug.
# SWFC_AGGREGATE_DEBUG=1

# =============================================================================
# ECAA emit-time validation
# =============================================================================
# After every successful emit, crates/conversation/src/emit/validation.rs
# runs the configured validators against the just-emitted ECAA sidecars
# and writes results to `runtime/validation-summary.json`. Warn-only by
# default — a validation failure does NOT block the emit.
#
# Production default (unset or schema_only): pure-Rust JSON Schema (draft-07)
# validation of the 8 sidecars. No Python runtime dep. Fast (~ms).
#
# `full` adds external Python validators:
#   - SHACL via pyshacl
#   - OWL DL satisfiability via HermiT (owlready2)
#   - runcrate validate (WRROC v0.5 round-trip)
# Each gracefully degrades to "Unavailable" if its deps aren't installed.
# Install once: pip install --user --break-system-packages pyshacl pyld owlready2 rdflib jsonschema runcrate
#
SWFC_VALIDATE_ON_EMIT=full
# SWFC_VALIDATE_ON_EMIT=schema_only   # default
# SWFC_VALIDATE_ON_EMIT=off           # escape hatch — skip all validation

# Override scripts/spec-check/ location if running from a non-default layout.
# SWFC_SPEC_SCRIPTS_DIR=/abs/path/to/scripps-workflow/scripts/spec-check

# Block emit on schema-validation failure (default warn-only).
# Useful for strict CI gates where a malformed sidecar should fail loudly.
# SWFC_VALIDATION_BLOCK_ON_FAIL=1

# Per-subprocess timeout for external Python validators (default 30s).
SWFC_VALIDATION_EXTERNAL_TIMEOUT_SECS=60

# ECAA emission mode. `full` (default) emits the eight ECAA v0.1
# sidecars every emit; `conventional` is the Arm B″ control that emits
# only conventional artifacts. Unknown values fall back to `full` with
# a tracing::warn!.
# SWFC_ECAA_MODE=full

# =============================================================================
# Ablation flags (Aim 3A Arm B′ — eval harness only, never in production)
# =============================================================================
# Each flag downgrades a single ECAA capability so the eval harness can
# measure its independent contribution. AblationFlag::all_flags()
# returns the canonical 6.
# SWFC_ABLATE_DECISION_RECORDS=1     # skip runtime/decisions.jsonl
# SWFC_ABLATE_AMENDMENT_PROVENANCE=1 # omit prov:wasDerivedFrom edges
# SWFC_ABLATE_CLAIM_CONSISTENCY=1    # skip runtime/claim-verification.json
# SWFC_ABLATE_TYPED_BLOCKERS=1       # downgrade typed blockers to generic
# SWFC_ABLATE_REEXECUTION_CLASS=1    # skip reexecution / determinism tracking
# SWFC_ABLATE_AUDIT_PROOF=1          # skip audit-proof-report emission
#
# PLANNED (pre-registered in docs/eval-prereg/PR-Arm-B-prime.md but NOT
# yet wired into code — setting these today is a no-op). Will become
# active in a subsequent landing of the Arm B′ ablation harness.
# SWFC_ABLATE_DECISION_LOG=1     # PLANNED: suppress runtime/decisions.jsonl variant
# SWFC_ABLATE_CLAIM_VERIFIER=1   # PLANNED: disable claim_extractor + claim_verifier
# SWFC_ABLATE_RESULT_REVIEW=1    # PLANNED: hide ResultReviewTurnCard (raw JSON)
# SWFC_ABLATE_FIGURE_PANEL=1     # PLANNED: disable plot-affordance rendering
# SWFC_ABLATE_REMEDIATION=1      # PLANNED: suppress remediation_proposer side-call
#
# PROPOSED gate (docs/2026-05/bug-audit-2026-05-16.md §392): requires
# SWFC_ABLATION_HARNESS=1 before any SWFC_ABLATE_* flag is honoured, so
# a stray flag in a prod env can't silently ablate a real run. NOT yet
# implemented in code.
# SWFC_ABLATION_HARNESS=1

# =============================================================================
# Harness watchdog + output guards
# =============================================================================
# Wall-clock watchdog that fires BlockerKind::TimeExceeded when a task
# runs longer than expected_wall_seconds × multiplier.

# Watchdog polling cadence (seconds). Default tracked in
# crates/harness/src/constants.rs; out-of-range values are clamped with
# a stderr warning.
# SWFC_WATCHDOG_PERIOD_SECS=30

# Per-task wall-clock multiplier. Default ~6× (tracked in constants.rs).
# A task expected to run for 60s is killed at 60×multiplier seconds.
# SWFC_WATCHDOG_MULTIPLIER=6.0

# Per-task output-directory size ceiling (MB). Unset = no cap; set a
# positive value to refuse dispatch of tasks whose accumulated outputs
# exceed the cap (surfaces as BlockerKind::OutputSizeExceeded).
# SWFC_TASK_OUTPUT_MAX_MB=10240

# Per-file size guard for swfc:// transport reads (MB). Default 100.
# SWFC_AGENT_FILE_MAX_MB=100

# Maximum tolerated clock skew between harness and agent host (seconds).
# Default 60. On breach the harness refuses dispatch and surfaces
# BlockerKind::ClockSkewExceeded.
# SWFC_CLOCK_SKEW_THRESHOLD_SECS=60

# Internal: harness sets this to 1 when re-running a task for
# determinism validation. Do not set manually.
# SWFC_DETERMINISM_RERUN=1

# =============================================================================
# Renderer-validator (Stage 12 — harness-set)
# =============================================================================
# Populated by crates/harness/src/renderer_validators.rs at dispatch
# time when an atom carries a renderer_module output. The harness
# exports them onto the validator subprocess and the bwrap allowlist
# threads them through. Do not set in your shell.
#   SWFC_RENDERER_MODULE  — Python module name (e.g. lib.plotting.stages.heatmap)
#   SWFC_RENDERER_OUT_DIR — output directory for renderer-validator scratch

# =============================================================================
# Runtime-set vars (populated by harness / server — DO NOT set manually)
# =============================================================================
# These are exported onto subprocess environments at dispatch time. Any
# shell-level value is silently overwritten on the next dispatch; only
# set them when reproducing a specific dispatch in isolation.
#
#   SWFC_TASK_ID                  — current task identity
#   SWFC_TASK_SCRATCH_DIR         — per-task scratch root visible to agent
#   SWFC_TASK_NETWORK             — per-task network policy (bridge | none)
#   SWFC_HARNESS_RUN_ID           — dispatch identity for WAL + heartbeat
#   SWFC_DISPATCH_EPOCH           — dispatch epoch timestamp
#   SWFC_HARNESS_BIN              — resolved harness binary path
#   SWFC_SERVER_BIN               — resolved server binary path
#   SWFC_SESSION_ID               — chat session identifier
#   SWFC_CHAT_SESSION_ID          — alias for SWFC_SESSION_ID (legacy)
#   SWFC_PACKAGE_ID               — currently-emitted package identifier
#   SWFC_S3_PACKAGE_URI           — S3 package rsync source (AWS)
#   SWFC_S3_OUTPUT_URI            — S3 output rsync destination (AWS)
#   SWFC_AWS_INSTANCE_ID          — EC2 instance ID (AWS)
#   SWFC_GIT_SHA                  — workspace SHA propagated into dispatch
#   SWFC_REMEDIATION_RATIONALE    — server-set rationale for retry/remediation
#   SWFC_HW_VCPUS_AVAILABLE       — per-agent CPU budget
#   SWFC_HW_MEMORY_GB             — per-agent memory budget
#   SWFC_HW_GPU                   — GPU envelope JSON
#   SWFC_HW_GPU_CAPABILITY_REF    — CUDA capability reference
#   SWFC_HW_RECOMMENDED_THREADS   — recommended thread count
#   SWFC_HW_TOOL_THREAD_CURVES    — tool → thread-curve coefficients
#   SWFC_HW_TASK_RESOURCE_CLASS   — resource-class label
#   SWFC_HW_CONCURRENT_PEERS_BY_CLASS — map of class → peer count
#   SWFC_HW_INTAKE_FACTS          — frozen intake facts for adaptive parallelism
#   SWFC_HW_ENV_OVERRIDES         — force-set BLAS/OpenMP env vars

# =============================================================================
# External integrations
# =============================================================================
# Hugging Face hub token. Required only when tasks declare a Hugging
# Face dataset/model in runtime_prereqs. Read by data_fetch.rs,
# biomystery/data.rs, and external/hf_fetcher.rs. Never logged.
# HF_TOKEN=hf_...

# Alternate name read by crates/eval-adapters/src/external/hf_fetcher.rs
# as a fallback when HF_TOKEN is unset. Pick one — setting both is
# redundant; HF_TOKEN takes precedence.
# HUGGINGFACE_TOKEN=hf_...

# Google Gemini API key. Required by the eval-adapters BiomniBench
# judge (crates/eval-adapters/src/external/judge.rs) which uses
# Gemini 3.1 Pro for rubric scoring. The eval harness skips judging
# when unset. Never logged.
# GEMINI_API_KEY=

# Cargo build artifact root. Redirect off the system disk when home is
# space-constrained.
CARGO_TARGET_DIR=$HOME/.cargo-target

# XDG state directory. Read by the upload route as a fallback for the
# upload root when SWFC_UPLOAD_ROOT is unset and $HOME is also missing.
# Standard XDG variable; most systems leave it unset.
# XDG_STATE_HOME=$HOME/.local/state

# =============================================================================
# Nekrutenko depth-eval (crates/eval-adapters/src/bin/eval-runner.rs)
# =============================================================================
# Selects modality for the 21-modality Nekrutenko depth-eval matrix.
# REQUIRED — the binary errors out with "NEKRUTENKO_MODALITY must be
# set for this suite" when unset.
# NEKRUTENKO_MODALITY=bulk-rnaseq

# Optional subset overrides forwarded onto the spawned adapter
# subprocess by apply_nekrutenko_subset_env in eval-runner.rs. Leave
# unset to run the full matrix.
# NEKRUTENKO_LEVELS=Track-B,v1g,v1.5
# NEKRUTENKO_PATTERNS=PATH-shim,missing-ref
# NEKRUTENKO_SEEDS=1,2,3

# =============================================================================
# Schema regeneration (developer-only)
# =============================================================================
# Regenerate JSON schemas in crates/conversation/tests/schemars_generation.rs
# instead of asserting against the committed schema. Set when a
# #[derive(JsonSchema)] struct changes and the test needs to write the
# new expected output to disk.
# SCHEMARS_REGEN=1
