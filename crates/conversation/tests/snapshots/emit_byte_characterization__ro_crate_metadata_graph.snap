    },
    {
      "@id": "#step-discover_alignment",
      "@type": "HowToStep",
      "additionalType": "discovery",
      "name": "Discover method for alignment (options: star, hisat2, bwa_mem2, bwa_mem, minimap2, bowtie2). Surface set_intake_method.",
      "position": 10
    },
    {
      "@id": "#step-data_acquisition",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Acquire raw experimental data from public repositories (SRA, GEO, ArrayExpress,\nENA, PRIDE, ClinVar, gnomAD, GTEx) or SME-supplied paths. Emits a cohort manifest,\nper-accession provenance summary, and an index pointing at the materialized\nartifacts. Downstream atoms consume the manifest, not the raw bytes directly.\n",
      "position": 11
    },
    {
      "@id": "#step-validate_data_acquisition",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Acquire raw experimental data from public repositories (SRA, GEO, ArrayExpress,\nENA, PRIDE, ClinVar, gnomAD, GTEx) or SME-supplied paths. Emits a cohort manifest,\nper-accession provenance summary, and an index pointing at the materialized\nartifacts. Downstream atoms consume the manifest, not the raw bytes directly.\n",
      "position": 12
    },
    {
      "@id": "#step-raw_qc",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Run sequencing QC (FastQC, MultiQC) on raw FASTQ inputs. Emits a per-sample metric\ntable and aggregated report; downstream `sequence_trimming` reads the trim-needed\nflag.\n",
      "position": 13
    },
    {
      "@id": "#step-validate_raw_qc",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Run sequencing QC (FastQC, MultiQC) on raw FASTQ inputs. Emits a per-sample metric\ntable and aggregated report; downstream `sequence_trimming` reads the trim-needed\nflag.\n",
      "position": 14
    },
    {
      "@id": "#step-sequence_trimming",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Trim adapters and low-quality bases from raw reads. Conditional in legacy\ntaxonomies on `raw_qc.result.needs_trimming`; the atom always runs and emits\ntrimmed FASTQ regardless of whether it altered the inputs (idempotent on\nalready-clean data).\n",
      "position": 15
    },
    {
      "@id": "#step-validate_sequence_trimming",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Trim adapters and low-quality bases from raw reads. Conditional in legacy\ntaxonomies on `raw_qc.result.needs_trimming`; the atom always runs and emits\ntrimmed FASTQ regardless of whether it altered the inputs (idempotent on\nalready-clean data).\n",
      "position": 16
    },
    {
      "@id": "#step-alignment",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Align trimmed reads to a reference genome. Method neutrality: the concrete\naligner (STAR / HISAT2 / BWA-MEM2 / minimap2 / Bowtie2 / Salmon-alevin)\nis selected at runtime by the agent. EDAM operation:3198 (Read mapping)\nis the more-specific child of operation:0292 (Sequence alignment).\n",
      "position": 17
    },
    {
      "@id": "#step-validate_alignment",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Align trimmed reads to a reference genome. Method neutrality: the concrete\naligner (STAR / HISAT2 / BWA-MEM2 / minimap2 / Bowtie2 / Salmon-alevin)\nis selected at runtime by the agent. EDAM operation:3198 (Read mapping)\nis the more-specific child of operation:0292 (Sequence alignment).\n",
      "position": 18
    },
    {
      "@id": "#step-quantification",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Quantify gene- or transcript-level expression from aligned reads. Method\nneutrality: featureCounts / HTSeq / Salmon / kallisto / RSEM are selected\nat runtime. Emits a count matrix consumed by downstream normalisation.\n",
      "position": 19
    },
    {
      "@id": "#step-validate_quantification",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Quantify gene- or transcript-level expression from aligned reads. Method\nneutrality: featureCounts / HTSeq / Salmon / kallisto / RSEM are selected\nat runtime. Emits a count matrix consumed by downstream normalisation.\n",
      "position": 20
    },
    {
      "@id": "#step-qc_preprocessing",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Apply count-matrix-level QC: cell or sample filtering by total counts, gene\ndetection, mitochondrial fraction, and doublet score. Distinct from `raw_qc`\n(which operates on raw reads). ecaax:scrnaseq_cell_qc per the EDAM audit —\nEDAM operation:3218 conflates raw-read QC with count-matrix QC.\n",
      "position": 21
    },
    {
      "@id": "#step-validate_qc_preprocessing",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Apply count-matrix-level QC: cell or sample filtering by total counts, gene\ndetection, mitochondrial fraction, and doublet score. Distinct from `raw_qc`\n(which operates on raw reads). ecaax:scrnaseq_cell_qc per the EDAM audit —\nEDAM operation:3218 conflates raw-read QC with count-matrix QC.\n",
      "position": 22
    },
    {
      "@id": "#step-normalisation",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Standardise expression values to remove library-size and composition biases.\nMethod neutrality: DESeq2 VST / edgeR TMM / scran pooling / Seurat\nLogNormalize / scnorm / sctransform are selected at runtime.\n",
      "position": 23
    },
    {
      "@id": "#step-validate_normalisation",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Standardise expression values to remove library-size and composition biases.\nMethod neutrality: DESeq2 VST / edgeR TMM / scran pooling / Seurat\nLogNormalize / scnorm / sctransform are selected at runtime.\n",
      "position": 24
    },
    {
      "@id": "#step-batch_correction",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Remove technical batch effects between donors / runs / sequencing centres\nwhile preserving biological signal. ecaax namespace per EDAM audit —\noperation:3435 conflates with normalisation.\n",
      "position": 25
    },
    {
      "@id": "#step-validate_batch_correction",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Remove technical batch effects between donors / runs / sequencing centres\nwhile preserving biological signal. ecaax namespace per EDAM audit —\noperation:3435 conflates with normalisation.\n",
      "position": 26
    },
    {
      "@id": "#step-integration",
      "@type": "HowToStep",
      "additionalType": "gate",
      "name": "Sensitivity comparison across batch-correction methods (Harmony / scVI /\nBBKNN / Scanorama). Materialises method-vs-method concordance metrics so\nthe SME can pick a winner via `select_sensitivity_winner`. Aggregator role\nbecause it fans in multiple corrected matrices.\n",
      "position": 27
    },
    {
      "@id": "#step-validate_integration",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Sensitivity comparison across batch-correction methods (Harmony / scVI /\nBBKNN / Scanorama). Materialises method-vs-method concordance metrics so\nthe SME can pick a winner via `select_sensitivity_winner`. Aggregator role\nbecause it fans in multiple corrected matrices.\n",
      "position": 28
    },
    {
      "@id": "#step-dimensionality_reduction",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Project the (normalised, batch-corrected) feature matrix to a low-dimensional\nembedding for visualization and clustering. PCA followed by UMAP or t-SNE is\nthe default; method choice deferred to runtime.\n",
      "position": 29
    },
    {
      "@id": "#step-validate_dimensionality_reduction",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Project the (normalised, batch-corrected) feature matrix to a low-dimensional\nembedding for visualization and clustering. PCA followed by UMAP or t-SNE is\nthe default; method choice deferred to runtime.\n",
      "position": 30
    },
    {
      "@id": "#step-clustering",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Group cells / samples by transcriptional similarity in the reduced embedding.\nLeiden / Louvain / k-means / hierarchical methods selected at runtime.\nResolution sweep is part of the emitted artifact so downstream review can\nre-pick without recomputation.\n",
      "position": 31
    },
    {
      "@id": "#step-validate_clustering",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Group cells / samples by transcriptional similarity in the reduced embedding.\nLeiden / Louvain / k-means / hierarchical methods selected at runtime.\nResolution sweep is part of the emitted artifact so downstream review can\nre-pick without recomputation.\n",
      "position": 32
    },
    {
      "@id": "#step-cell_type_annotation",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Label each cluster with a cell-identity from marker-gene panels or reference\nmapping (CellTypist / SingleR / Azimuth / sctype). ecaax namespace per the\nEDAM audit — operation:0361 (sequence annotation) is a semantic mismatch\nfor cell-identity calling on count matrices.\n",
      "position": 33
    },
    {
      "@id": "#step-validate_cell_type_annotation",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Label each cluster with a cell-identity from marker-gene panels or reference\nmapping (CellTypist / SingleR / Azimuth / sctype). ecaax namespace per the\nEDAM audit — operation:0361 (sequence annotation) is a semantic mismatch\nfor cell-identity calling on count matrices.\n",
      "position": 34
    },
    {
      "@id": "#step-differential_expression",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Test for differentially expressed genes between conditions / cell types.\nDESeq2 / edgeR / limma-voom / MAST / Wilcoxon selected at runtime based on\nmodality (bulk vs single-cell) and design.\n",
      "position": 35
    },
    {
      "@id": "#step-validate_differential_expression",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Test for differentially expressed genes between conditions / cell types.\nDESeq2 / edgeR / limma-voom / MAST / Wilcoxon selected at runtime based on\nmodality (bulk vs single-cell) and design.\n",
      "position": 36
    },
    {
      "@id": "#step-pathway_enrichment",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Test pre-defined gene sets (KEGG / Reactome / GO / MSigDB hallmark) against\nranked DE results. fgsea / clusterProfiler / GSEA / enrichr selected at runtime.\n",
      "position": 37
    },
    {
      "@id": "#step-validate_pathway_enrichment",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Test pre-defined gene sets (KEGG / Reactome / GO / MSigDB hallmark) against\nranked DE results. fgsea / clusterProfiler / GSEA / enrichr selected at runtime.\n",
      "position": 38
    },
    {
      "@id": "#step-reporting",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Assemble narrative tables, figures, and summary text from upstream stage\noutputs into a per-stage HTML / Markdown report. Modality-agnostic; bio\ntaxonomies override the description at the include site to specify what\ngoes into the report.\n",
      "position": 39
    },
    {
      "@id": "#step-validate_reporting",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Assemble narrative tables, figures, and summary text from upstream stage\noutputs into a per-stage HTML / Markdown report. Modality-agnostic; bio\ntaxonomies override the description at the include site to specify what\ngoes into the report.\n",
      "position": 40
    },
    {
      "@id": "#step-final_reporting",
      "@type": "HowToStep",
      "additionalType": "computation",
      "name": "Assemble the project-level final report: cross-stage narrative, dashboard\nindex, key figures, methods + caveats. Final node before SME review.\n",
      "position": 41
    },
    {
      "@id": "#step-validate_final_reporting",
      "@type": "HowToStep",
      "additionalType": "validation",
      "name": "Validate outputs of: Assemble the project-level final report: cross-stage narrative, dashboard\nindex, key figures, methods + caveats. Final node before SME review.\n",
      "position": 42
    },
