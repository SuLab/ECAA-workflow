{
  "_preset_name": "nature",
  "_description": "Nature Research style. Single-column 89mm, double-column 183mm. Helvetica primary, 7pt minimum text, Type 1/TrueType fonts only, 300dpi PNG / vector PDF.",
  "_reference": "https://www.nature.com/nature/for-authors/final-submission",
  "fonts": {
    "family": "sans-serif",
    "stack": ["Helvetica", "Arial", "DejaVu Sans"],
    "body_pt": 7,
    "title_pt": 8,
    "tick_pt": 6,
    "legend_pt": 6,
    "footer_pt": 5
  },
  "axes": {
    "linewidth": 0.5,
    "spines_top": false,
    "spines_right": false,
    "constrained_layout": true
  },
  "output": {
    "png_dpi": 300,
    "formats": ["png", "pdf"],
    "pdf_fonttype": 42,
    "svg_fonttype": "none",
    "rasterize_threshold_n": 50000,
    "single_column_mm": 89,
    "double_column_mm": 183
  }
}
